# =============================================================================
# MDS Deployment Profile Defaults
# =============================================================================
# Git-tracked fleet-level deployment defaults.
#
# This file is the canonical repo-owned default layer for:
#   - default code-sync repository selection
#   - default code-sync branch
#   - fallback GCS addressing defaults by runtime mode
#   - default GCS API port
#   - optional connectivity backend defaults
#
# Host-local rendered runtime files still override these values:
#   - /etc/mds/gcs.env
#   - /etc/mds/local.env
#
# Process environment still overrides everything when explicitly set.
# =============================================================================

MDS_DEFAULT_PROFILE_ID=official-default
MDS_DEFAULT_REPO_SLUG=alireza787b/mavsdk_drone_show
MDS_DEFAULT_REPO_URL_HTTPS=https://github.com/alireza787b/mavsdk_drone_show.git
MDS_DEFAULT_REPO_URL_SSH=git@github.com:alireza787b/mavsdk_drone_show.git
MDS_DEFAULT_BRANCH=main

MDS_DEFAULT_REAL_GCS_IP=100.96.32.75
MDS_DEFAULT_SITL_GCS_IP=172.18.0.1
MDS_DEFAULT_GCS_API_PORT=5030
MDS_DEFAULT_DASHBOARD_PORT=3030
MDS_DEFAULT_DRONE_API_PORT=7070
MDS_DEFAULT_DOCKER_IMAGE=mavsdk-drone-show-sitl:latest

MDS_DEFAULT_CONNECTIVITY_BACKEND=none
MDS_DEFAULT_SMART_WIFI_MANAGER_REPO_SLUG=alireza787b/smart-wifi-manager
MDS_DEFAULT_SMART_WIFI_MANAGER_REPO_URL_HTTPS=https://github.com/alireza787b/smart-wifi-manager.git
MDS_DEFAULT_SMART_WIFI_MANAGER_REF=v2.1.3
MDS_DEFAULT_SMART_WIFI_MANAGER_MODE=observe
MDS_DEFAULT_SMART_WIFI_MANAGER_IMPORT_MODE=replace
MDS_DEFAULT_SMART_WIFI_MANAGER_INSTALL_DIR=/opt/smart-wifi-manager
MDS_DEFAULT_SMART_WIFI_MANAGER_DASHBOARD_LISTEN=127.0.0.1:9080
MDS_DEFAULT_SMART_WIFI_MANAGER_PROFILE_PATH=deployment/connectivity/smart-wifi-manager/profile.json

MDS_DEFAULT_MAVLINK_MANAGEMENT_MODE=managed
MDS_DEFAULT_MAVLINK_ANYWHERE_REPO_SLUG=alireza787b/mavlink-anywhere
MDS_DEFAULT_MAVLINK_ANYWHERE_REPO_URL_HTTPS=https://github.com/alireza787b/mavlink-anywhere.git
MDS_DEFAULT_MAVLINK_ANYWHERE_REF=v3.0.8
MDS_DEFAULT_MAVLINK_ANYWHERE_INSTALL_DIR=/opt/mavlink-anywhere
MDS_DEFAULT_MAVLINK_ANYWHERE_DASHBOARD_LISTEN=127.0.0.1:9070
MDS_DEFAULT_MAVLINK_ANYWHERE_SKIP_DASHBOARD=false
