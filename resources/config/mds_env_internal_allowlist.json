{
  "version": 1,
  "description": "Process-only MDS_* variables that are intentionally not operator-editable registry entries.",
  "rules": [
    {
      "pattern": "MDS_ASKPASS_*",
      "domain": "git",
      "scope": "process",
      "reason": "Temporary child-process Git askpass transport; never store or edit through operator UI."
    },
    {
      "pattern": "MDS_GIT_SYNC_*",
      "domain": "git",
      "scope": "process",
      "reason": "Transient git-sync runtime state and re-exec guard variables."
    },
    {
      "pattern": "MDS_IMAGE_*",
      "domain": "sitl",
      "scope": "build",
      "reason": "Generated SITL image-build metadata; not a runtime operator setting."
    },
    {
      "pattern": "MDS_SITL_*",
      "domain": "sitl",
      "scope": "launcher",
      "reason": "Expert SITL launcher/image controls. Keep documented in SITL guides, not editable from the GCS env UI."
    },
    {
      "pattern": "MDS_PROD_*",
      "domain": "frontend",
      "scope": "launcher",
      "reason": "Dashboard production server process tuning; launcher-only."
    },
    {
      "pattern": "MDS_ULOG_*",
      "domain": "logging",
      "scope": "process",
      "reason": "ULog staging/downloader internals; not operator env profile data."
    },
    {
      "pattern": "MDS_VERSION_*",
      "domain": "system",
      "scope": "process",
      "reason": "Version override/test variables for deterministic build/version reporting."
    }
  ],
  "keys": [
    {
      "name": "MDS_ALLOW_NPM_INSTALL_FALLBACK",
      "domain": "frontend",
      "scope": "launcher",
      "reason": "Dashboard launcher fallback guard; not persisted operator config."
    },
    {
      "name": "MDS_BACKUP_COUNT",
      "domain": "logging",
      "scope": "documentation",
      "reason": "Commented example only; canonical logging key is MDS_LOG_BACKUP_COUNT."
    },
    {
      "name": "MDS_BANNER_PATH",
      "domain": "frontend",
      "scope": "launcher",
      "reason": "Optional launcher banner path."
    },
    {
      "name": "MDS_BANNER_VERSION",
      "domain": "frontend",
      "scope": "launcher",
      "reason": "Optional launcher banner version string."
    },
    {
      "name": "MDS_BASE_DIR",
      "domain": "runtime",
      "scope": "process",
      "reason": "Container/process runtime root injected by launchers."
    },
    {
      "name": "MDS_COMMIT",
      "domain": "system",
      "scope": "process",
      "reason": "Build/version metadata override."
    },
    {
      "name": "MDS_COMMON_PARAMS_FILE",
      "domain": "px4",
      "scope": "process",
      "reason": "PX4 parameter helper input path; managed by parameter workflow docs."
    },
    {
      "name": "MDS_CONFIG_DIR",
      "domain": "runtime",
      "scope": "bootstrap",
      "reason": "Bootstrap library constant for /etc/mds."
    },
    {
      "name": "MDS_CONFIG_URL",
      "domain": "runtime",
      "scope": "advanced",
      "reason": "Optional external config publisher endpoint; local config remains default."
    },
    {
      "name": "MDS_CONNECTIVITY_STATE_DIR",
      "domain": "connectivity",
      "scope": "process",
      "reason": "Connectivity reconcile state directory."
    },
    {
      "name": "MDS_COORDINATOR_RESTART_FALLBACK_ENABLED",
      "domain": "system",
      "scope": "node_service",
      "reason": "Node service restart fallback control."
