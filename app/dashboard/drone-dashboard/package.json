{
  "name": "drone-dashboard",
  "version": "5.3",
  "private": true,
  "license": "CC-BY-NC-SA-4.0",
  "homepage": "/",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10 <11"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@mui/material": "^6.4.1",
    "@mui/x-data-grid": "^7.28.0",
    "@react-three/drei": "^9.80.2",
    "@react-three/fiber": "^8.18.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^13.5.0",
    "@turf/area": "^7.3.4",
    "@turf/buffer": "^7.3.4",
    "@turf/distance": "^7.2.0",
    "@turf/helpers": "^7.3.4",
    "axios": "^1.7.7",
    "classnames": "^2.3.2",
    "coordinate-parser": "^1.0.7",
    "cytoscape": "^3.26.0",
    "geodesy": "^2.4.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "mapbox-gl": "^2.15.0",
    "papaparse": "^5.4.1",
    "plotly.js-dist": "^2.25.2",
    "postcss": "^8.4.39",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-leaflet": "^4.2.1",
    "react-leaflet-fullscreen": "^4.1.0",
    "react-map-gl": "^7.1.9",
    "react-plotly.js": "^2.6.0",
    "react-pro-sidebar": "^1.1.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "^5.0.1",
    "react-time-picker": "^7.0.0",
    "react-toastify": "^10.0.6",
    "react-tooltip": "^5.28.0",
    "react-transition-group": "^4.4.5",
    "three": "^0.166.1"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--max-old-space-size=4096 PORT=3030 react-scripts start",
    "build": "GENERATE_SOURCEMAP=false NODE_OPTIONS=--max-old-space-size=4096 react-scripts build",
    "test": "react-scripts test",
    "audit:ui": "python3 ../../../tools/audit_frontend_ui.py --strict",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "no-console": [
        "warn",
        {
          "allow": [
            "error",
            "warn",
            "info",
            "group",
            "groupEnd"
          ]
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-keywords": "^5.1.0",
    "eslint-plugin-jest": "^27.2.3"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-leaflet|@react-leaflet/core)/)"
    ],
    "moduleNameMapper": {
      "\\.(css)$": "<rootDir>/src/__mocks__/styleMock.js",
      "^react-cytoscapejs$": "<rootDir>/src/__mocks__/styleMock.js",
      "^mapbox-gl$": "<rootDir>/src/__mocks__/styleMock.js"
    }
  }
}
