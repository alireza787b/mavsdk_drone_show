# ============================================
# MAVSDK Drone Show - React Dashboard Configuration
# ============================================

# --------------------------------------------
# Mapbox Configuration
# --------------------------------------------
# Mapbox Access Token (free tier: 50,000 map loads/month)
# Get your token from: https://www.mapbox.com/
# Leave empty for automatic OpenStreetMap/Leaflet fallback (works without Mapbox)
REACT_APP_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Map Provider Override (optional)
# Set to 'leaflet' to force OpenStreetMap even when Mapbox token is available
# Leave empty for automatic detection (Mapbox primary, Leaflet fallback)
# REACT_APP_MAP_PROVIDER=

# --------------------------------------------
# GCS Server Configuration
# --------------------------------------------
# GCS (Ground Control Station) server connection
#
# AUTO-DETECTION (Recommended):
# Leave REACT_APP_SERVER_URL commented out or empty.
# The dashboard will auto-detect the server URL from the browser location.
# This works automatically in all environments:
#   - SITL on localhost -> uses localhost
#   - Production on 192.168.1.100 -> uses 192.168.1.100
#   - Any network configuration -> no rebuild needed
#
# MANUAL OVERRIDE (Advanced):
# Only set this if you need to override auto-detection
# (e.g., dashboard served from different host than GCS server)
# REACT_APP_SERVER_URL=http://192.168.1.100

# GCS server port (FastAPI backend)
REACT_APP_GCS_PORT=5030

# --------------------------------------------
# Drone API Server Configuration
# --------------------------------------------
# Port for drone-side API servers (FastAPI)
REACT_APP_DRONE_PORT=7070

# --------------------------------------------
# React Development Server
# --------------------------------------------
# React development server port (not the backend)
PORT=3030

# --------------------------------------------
# Development Optimizations
# --------------------------------------------
# Disable source maps for faster builds
GENERATE_SOURCEMAP=false

# Skip preflight checks (create-react-app)
SKIP_PREFLIGHT_CHECK=true

# Disable host check (for remote access during development)
# WARNING: Only use in controlled environments
DANGEROUSLY_DISABLE_HOST_CHECK=true

# --------------------------------------------
# Backend Type (Optional)
# --------------------------------------------
# Specify which backend is running (for documentation purposes)
# Backend: FastAPI (fully migrated)
REACT_APP_BACKEND_TYPE=fastapi

# --------------------------------------------
# API Base URLs (Computed from above)
# --------------------------------------------
# These are computed in the frontend code:
# GCS API: ${REACT_APP_SERVER_URL}:${REACT_APP_GCS_PORT}
# Drone API: ${REACT_APP_SERVER_URL}:${REACT_APP_DRONE_PORT}

# --------------------------------------------
# Production Settings
# --------------------------------------------
# For production deployment:
# - Server URL auto-detects from browser (no changes needed)
# - Remove DANGEROUSLY_DISABLE_HOST_CHECK
# - Keep GENERATE_SOURCEMAP=false (already set)
#
# The dashboard automatically uses the same hostname as the browser URL.
# Example: If accessed at http://192.168.1.100:3030, API calls go to
# http://192.168.1.100:5030 (using REACT_APP_GCS_PORT)

# ============================================
# Advanced: Manual Server Override
# ============================================
# Only needed if GCS server runs on a different host than the dashboard.
# Most deployments should NOT need this.
#
# Example: Dashboard on 192.168.1.100, GCS server on 192.168.1.200
# REACT_APP_SERVER_URL=http://192.168.1.200
# REACT_APP_GCS_PORT=5030
